function(ADD_IDA_PLUGIN target_name)

INCLUDE_DIRECTORIES(${IDASDK_DIR}/include)

ADD_LIBRARY(${target_name} SHARED ${ARGN})
SET_TARGET_PROPERTIES(${target_name} PROPERTIES PREFIX "")

IF(NOT ${UNI64})
  ADD_LIBRARY(${target_name}_64 SHARED ${ARGN})
  SET_TARGET_PROPERTIES(${target_name}_64 PROPERTIES PREFIX "")
ENDIF()

SET(CMAKE_CXX_STANDARD 17)
SET(OPT_CXX_FLAGS "-std=c++17 -flto -fvisibility=hidden -fvisibility-inlines-hidden")
SET(IDA_COMMON_CXX_FLAGS "-D__X64__ -DUSE_DANGEROUS_FUNCTIONS")

SET(IDA_LIB_DIR_SUFFIX_32 "_32")
SET(IDA_LIB_DIR_SUFFIX_64 "_64")
SET(IDA_LIB_NAME "ida")
SET(IDA_LIB_32_SUFFIX "")
SET(IDA_LIB_64_SUFFIX "")
SET(IDA_LINK_ARGS "")

IF(MSVC)
  SET(COMMON_FLAGS "${CMAKE_CXX_FLAGS} /std:c++17 -D __NT__ ${IDA_COMMON_CXX_FLAGS} ")
  IF("${CMAKE_SYSTEM_PROCESSOR}" STREQUAL "arm64")
    SET(IDA_ARCH "arm64")
  ELSE()
    SET(IDA_ARCH "x64")
  ENDIF()
  SET(IDA_PLATFORM "win")
  SET(IDA_COMPILER_NAME "vc")
  SET(IDA_LIB_PREFIX "")
  SET(IDA_LIB_EXTENSION ".lib")
ELSEIF(APPLE)
  SET(COMMON_FLAGS "${CMAKE_CXX_FLAGS} -D__MAC__ ${IDA_COMMON_CXX_FLAGS}  ${OPT_CXX_FLAGS}")
  IF("${CMAKE_SYSTEM_PROCESSOR}" STREQUAL "arm64")
    SET(IDA_ARCH "arm64")
  ELSE()
    SET(IDA_ARCH "x64")
  ENDIF()
  SET(IDA_PLATFORM "mac")
  SET(IDA_COMPILER_NAME "clang")
  SET(IDA_LIB_PREFIX "lib")
  SET(IDA_LIB_64_SUFFIX "64")
  SET(IDA_LIB_EXTENSION ".dylib")
  SET(IDA_LINK_ARGS "-flto")
ELSEIF("${CMAKE_SYSTEM_NAME}" STREQUAL "Linux")
  SET(COMMON_FLAGS "${CMAKE_CXX_FLAGS} -D__LINUX__ ${IDA_COMMON_CXX_FLAGS} ${OPT_CXX_FLAGS}")
  SET(GCC_LINK_FLAGS "-Wl,--version-script=${IDASDK_DIR}/plugins/exports.def -Wl,--strip-debug,--discard-all,--strip-all,--discard-locals -flto=auto")
  IF("${CMAKE_SYSTEM_PROCESSOR}" STREQUAL "aarch64")
    SET(IDA_ARCH "arm64")
  ELSE()
    SET(IDA_ARCH "x64")
  ENDIF()
  SET(IDA_PLATFORM "linux")
  SET(IDA_COMPILER_NAME "gcc")
  SET(IDA_LIB_PREFIX "lib")
  SET(IDA_LIB_64_SUFFIX "64")
  SET(IDA_LIB_EXTENSION ".so")
  SET(IDA_LINK_ARGS "${OPT_CXX_FLAGS}" "${GCC_LINK_FLAGS}")
ELSE()
  MESSAGE(FATAL_ERROR "Unsupported system type: ${CMAKE_SYSTEM_NAME}")
ENDIF()

SET(IDA_COMPILER_PART "")
IF(IDA_COMPILER_NAME)
  SET(IDA_COMPILER_PART "_${IDA_COMPILER_NAME}")
ENDIF()

SET(IDA_LIB_DIR_BASE "${IDA_ARCH}_${IDA_PLATFORM}")
SET(IDA_LIB_DIR_32 "")
SET(IDA_LIB_DIR_64 "")

FOREACH(IDA_LIB_LAYOUT IN ITEMS plain compiler compiler_pro)
  IF(IDA_LIB_LAYOUT STREQUAL "plain")
    SET(IDA_LIB_DIR_PREFIX "${IDA_LIB_DIR_BASE}")
    SET(IDA_LIB_DIR_PRO_SUFFIX "")
  ELSEIF(IDA_LIB_LAYOUT STREQUAL "compiler")
    SET(IDA_LIB_DIR_PREFIX "${IDA_LIB_DIR_BASE}${IDA_COMPILER_PART}")
    SET(IDA_LIB_DIR_PRO_SUFFIX "")
  ELSEIF(IDA_LIB_LAYOUT STREQUAL "compiler_pro")
    SET(IDA_LIB_DIR_PREFIX "${IDA_LIB_DIR_BASE}${IDA_COMPILER_PART}")
    SET(IDA_LIB_DIR_PRO_SUFFIX "_pro")
  ELSE()
    MESSAGE(FATAL_ERROR "Unknown IDA SDK library layout: ${IDA_LIB_LAYOUT}")
  ENDIF()

  SET(IDA_LIB_DIR_64_CANDIDATE "${IDA_LIB_DIR_PREFIX}${IDA_LIB_DIR_SUFFIX_64}${IDA_LIB_DIR_PRO_SUFFIX}")
  SET(IDA_LIB_DIR_32_CANDIDATE "${IDA_LIB_DIR_PREFIX}${IDA_LIB_DIR_SUFFIX_32}${IDA_LIB_DIR_PRO_SUFFIX}")
  IF(EXISTS "${IDASDK_DIR}/lib/${IDA_LIB_DIR_64_CANDIDATE}")
    SET(IDA_LIB_DIR_32 "${IDA_LIB_DIR_32_CANDIDATE}")
    SET(IDA_LIB_DIR_64 "${IDA_LIB_DIR_64_CANDIDATE}")
    BREAK()
  ENDIF()
ENDFOREACH()

IF(NOT IDA_LIB_DIR_64)
  MESSAGE(FATAL_ERROR "IDA SDK libraries were not found in ${IDASDK_DIR}/lib")
ENDIF()

SET(IDA_LIB_FILE_32 "${IDA_LIB_PREFIX}${IDA_LIB_NAME}${IDA_LIB_32_SUFFIX}${IDA_LIB_EXTENSION}")
SET(IDA_LIB_FILE_64 "${IDA_LIB_PREFIX}${IDA_LIB_NAME}${IDA_LIB_64_SUFFIX}${IDA_LIB_EXTENSION}")
SET(IDA_LIB_PATH_32 "${IDASDK_DIR}/lib/${IDA_LIB_DIR_32}/${IDA_LIB_FILE_32}")
SET(IDA_LIB_PATH_64 "${IDASDK_DIR}/lib/${IDA_LIB_DIR_64}/${IDA_LIB_FILE_64}")

IF(${UNI64})
  SET(IDA_LIB_PATH "${IDASDK_DIR}/lib/${IDA_LIB_DIR_64}/${IDA_LIB_FILE_32}")
  IF(NOT EXISTS "${IDA_LIB_PATH}")
    MESSAGE(FATAL_ERROR "IDA SDK library was not found: ${IDA_LIB_PATH}")
  ENDIF()
  TARGET_LINK_LIBRARIES(${target_name} ${IDA_LIB_PATH} ${IDA_LINK_ARGS})
ELSE()
  IF(NOT EXISTS "${IDA_LIB_PATH_32}")
    MESSAGE(FATAL_ERROR "IDA SDK library was not found: ${IDA_LIB_PATH_32}")
  ENDIF()
  IF(NOT EXISTS "${IDA_LIB_PATH_64}")
    MESSAGE(FATAL_ERROR "IDA SDK library was not found: ${IDA_LIB_PATH_64}")
  ENDIF()
  TARGET_LINK_LIBRARIES(${target_name}    ${IDA_LIB_PATH_32} ${IDA_LINK_ARGS})
  TARGET_LINK_LIBRARIES(${target_name}_64 ${IDA_LIB_PATH_64} ${IDA_LINK_ARGS})
ENDIF()

IF(${UNI64})
  SET_TARGET_PROPERTIES(${target_name}    PROPERTIES COMPILE_FLAGS "${COMMON_FLAGS} -D__EA64__")
  SET_TARGET_PROPERTIES(${target_name}    PROPERTIES OUTPUT_NAME   "${target_name}")
ELSE()
  SET_TARGET_PROPERTIES(${target_name}    PROPERTIES COMPILE_FLAGS "${COMMON_FLAGS}")
  SET_TARGET_PROPERTIES(${target_name}_64 PROPERTIES COMPILE_FLAGS "${COMMON_FLAGS} -D__EA64__")
  SET_TARGET_PROPERTIES(${target_name}    PROPERTIES OUTPUT_NAME   "${target_name}")
  SET_TARGET_PROPERTIES(${target_name}_64 PROPERTIES OUTPUT_NAME   "${target_name}64")
ENDIF()

endfunction()
