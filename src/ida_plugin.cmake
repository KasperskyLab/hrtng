function(ADD_IDA_PLUGIN target_name)

INCLUDE_DIRECTORIES(${IDASDK_DIR}/include)

ADD_LIBRARY(${target_name} SHARED ${ARGN})
SET_TARGET_PROPERTIES(${target_name} PROPERTIES PREFIX "")

IF(NOT ${UNI64})
  ADD_LIBRARY(${target_name}_64 SHARED ${ARGN})
  SET_TARGET_PROPERTIES(${target_name}_64 PROPERTIES PREFIX "")
ENDIF()

SET(CMAKE_CXX_STANDARD 17)
SET(OPT_CXX_FLAGS "-std=c++17 -flto -fvisibility=hidden -fvisibility-inlines-hidden")
SET(IDA_COMMON_CXX_FLAGS "-D__X64__ -DUSE_DANGEROUS_FUNCTIONS")

IF(${IDASDK_VER} STREQUAL "83" OR ${IDASDK_VER} STREQUAL "84")
  SET(PRO "_pro")
ELSE()
  SET(PRO "")
ENDIF()

SET(IDA_LIB_DIR_SUFFIX_32 "_32${PRO}")
SET(IDA_LIB_DIR_SUFFIX_64 "_64${PRO}")

IF(MSVC)
  SET(COMMON_FLAGS "${CMAKE_CXX_FLAGS} /std:c++17 -D __NT__ ${IDA_COMMON_CXX_FLAGS} ")
  IF(${UNI64})
    TARGET_LINK_LIBRARIES(${target_name} ${IDASDK_DIR}/lib/${IDA_WIN_LIB_DIR_64}/ida.lib)
  ELSE()
    TARGET_LINK_LIBRARIES(${target_name} ${IDASDK_DIR}/lib/${IDA_WIN_LIB_DIR_32}/ida.lib)
    TARGET_LINK_LIBRARIES(${target_name}_64 ${IDASDK_DIR}/lib/${IDA_WIN_LIB_DIR_64}/ida.lib)
  ENDIF()
ELSEIF(APPLE)
  SET(COMMON_FLAGS "${CMAKE_CXX_FLAGS} -D__MAC__ ${IDA_COMMON_CXX_FLAGS}  ${OPT_CXX_FLAGS}")
  IF("${CMAKE_SYSTEM_PROCESSOR}" STREQUAL "arm64")
    SET(IDA_MAC_ARCH "arm64")
  ELSE()
    SET(IDA_MAC_ARCH "x64")
  ENDIF()
  SET(IDA_COMPILER_NAME "_clang")
  IF(EXISTS "${IDASDK_DIR}/lib/${IDA_MAC_ARCH}_mac${IDA_LIB_DIR_SUFFIX_64}")
    SET(IDA_COMPILER_NAME "")
  ENDIF()
  SET(IDA_MAC_LIB_DIR_32 "${IDA_MAC_ARCH}_mac${IDA_COMPILER_NAME}${IDA_LIB_DIR_SUFFIX_32}")
  SET(IDA_MAC_LIB_DIR_64 "${IDA_MAC_ARCH}_mac${IDA_COMPILER_NAME}${IDA_LIB_DIR_SUFFIX_64}")
  IF(${UNI64})
    TARGET_LINK_LIBRARIES(${target_name} ${IDASDK_DIR}/lib/${IDA_MAC_LIB_DIR_64}/libida.dylib -flto)
  ELSE()
    TARGET_LINK_LIBRARIES(${target_name} ${IDASDK_DIR}/lib/${IDA_MAC_LIB_DIR_32}/libida.dylib -flto)
    TARGET_LINK_LIBRARIES(${target_name}_64 ${IDASDK_DIR}/lib/${IDA_MAC_LIB_DIR_64}/libida64.dylib -flto)
  ENDIF()
ELSEIF(${CMAKE_SYSTEM_NAME} STREQUAL "Linux")
  SET(COMMON_FLAGS "${CMAKE_CXX_FLAGS} -D__LINUX__ ${IDA_COMMON_CXX_FLAGS} ${OPT_CXX_FLAGS}")
  SET(GCC_LINK_FLAGS "-Wl,--version-script=${IDASDK_DIR}/plugins/exports.def -Wl,--strip-debug,--discard-all,--strip-all,--discard-locals -flto=auto")
  IF("${CMAKE_SYSTEM_PROCESSOR}" STREQUAL "aarch64")
    SET(IDA_LINUX_ARCH "arm64")
  ELSE()
    SET(IDA_LINUX_ARCH "x64")
  ENDIF()
  SET(IDA_COMPILER_NAME "_gcc")
  IF(EXISTS "${IDASDK_DIR}/lib/${IDA_LINUX_ARCH}_linux${IDA_LIB_DIR_SUFFIX_64}")
    SET(IDA_COMPILER_NAME "")
  ENDIF()
  SET(IDA_LINUX_LIB_DIR_32 "${IDA_LINUX_ARCH}_linux${IDA_COMPILER_NAME}${IDA_LIB_DIR_SUFFIX_32}")
  SET(IDA_LINUX_LIB_DIR_64 "${IDA_LINUX_ARCH}_linux${IDA_COMPILER_NAME}${IDA_LIB_DIR_SUFFIX_64}")
  IF("${IDA_LINUX_ARCH}" STREQUAL "arm64" AND NOT EXISTS "${IDASDK_DIR}/lib/${IDA_LINUX_LIB_DIR_64}/libida.so")
    MESSAGE(FATAL_ERROR "Linux arm64 IDA SDK libraries were not found in ${IDASDK_DIR}/lib/${IDA_LINUX_LIB_DIR_64}; use an IDA SDK with HexRaysSA/ida-sdk#46 merged")
  ENDIF()
  IF(${UNI64})
    TARGET_LINK_LIBRARIES(${target_name} ${IDASDK_DIR}/lib/${IDA_LINUX_LIB_DIR_64}/libida.so ${OPT_CXX_FLAGS} ${GCC_LINK_FLAGS})
  ELSE()
    TARGET_LINK_LIBRARIES(${target_name} ${IDASDK_DIR}/lib/${IDA_LINUX_LIB_DIR_32}/libida.so ${OPT_CXX_FLAGS} ${GCC_LINK_FLAGS})
    TARGET_LINK_LIBRARIES(${target_name}_64 ${IDASDK_DIR}/lib/${IDA_LINUX_LIB_DIR_64}/libida64.so ${OPT_CXX_FLAGS} ${GCC_LINK_FLAGS})
  ENDIF()
ENDIF()

IF(${UNI64})
  SET_TARGET_PROPERTIES(${target_name} PROPERTIES COMPILE_FLAGS "${COMMON_FLAGS} -D__EA64__")
  SET_TARGET_PROPERTIES(${target_name} PROPERTIES OUTPUT_NAME "${target_name}")
ELSE()
  SET_TARGET_PROPERTIES(${target_name} PROPERTIES COMPILE_FLAGS ${COMMON_FLAGS})
  SET_TARGET_PROPERTIES(${target_name}_64 PROPERTIES COMPILE_FLAGS "${COMMON_FLAGS} -D__EA64__")
  SET_TARGET_PROPERTIES(${target_name} PROPERTIES OUTPUT_NAME "${target_name}")
  SET_TARGET_PROPERTIES(${target_name}_64 PROPERTIES OUTPUT_NAME "${target_name}64")
ENDIF()

endfunction()
